{
  "name": "arb-editor",
  "publisher": "Google",
  "displayName": "ARB Editor",
  "description": "Editor for Application Resource Bundle files, used for localization.",
  "version": "0.2.2",
  "engines": {
    "vscode": "^1.106.1"
  },
  "homepage": "https://github.com/google/arb-editor",
  "bugs": {
    "url": "https://github.com/google/arb-editor/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/google/arb-editor"
  },
  "license": "Apache-2.0",
  "author": "Moritz Sümmermann <mosum@google.com>",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:json",
    "onLanguage:dart"
  ],
  "icon": "media/logo.png",
  "main": "./out/extension.js",
  "contributes": {
    "jsonValidation": [
      {
        "fileMatch": "*.arb",
        "url": "./schemas/arb.json"
      }
    ],
    "languages": [
      {
        "id": "json",
        "extensions": [
          "arb"
        ]
      }
    ],
    "configuration": {
      "type": "object",
      "title": "ARB Editor",
      "properties": {
        "arb-editor.suppressedWarnings": {
          "description": "Suppress warnings in ARB Editor.",
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "all"
              ],
              "description": "Suppress all warnings in arbEditor."
            },
            {
              "type": "array",
              "default": [],
              "description": "Suppress specific warnings in arbEditor.",
              "items": {
                "type": "string",
                "description": "The warnings to suppress.",
                "minItems": 0,
                "maxItems": 10,
                "uniqueItems": true,
                "enum": [
                  "mismatched_brackets",
                  "metadata_for_missing_key",
                  "invalid_key",
                  "missing_metadata_for_key",
                  "invalid_placeholder",
                  "missing_other_in_icu",
                  "unknown_icu_message_type",
                  "placeholder_without_metadata",
                  "missing_placeholder_with_metadata",
                  "missing_messages_from_template"
                ]
              }
            }
          ]
        },
        "arb-editor.enableAppLocalizationsCodeLens": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable AppLocalizations CodeLens in Dart files."
        },
        "arb-editor.appLocalizationsCodeLensLanguageMode": {
          "type": "string",
          "enum": [
            "definedByYaml",
            "custom"
          ],
          "default": "definedByYaml",
          "markdownDescription": "Selects how the `lang` template variable is resolved for AppLocalizations CodeLens text.\n\n- `definedByYaml`: uses language defined in the `template-arb-file` value of `l10n.yaml` file.\n- `custom`: uses `#arb-editor.appLocalizationsCodeLensCustomLanguage#`."
        },
        "arb-editor.appLocalizationsCodeLensCustomLanguage": {
          "type": "string",
          "default": "en",
          "markdownDescription": "Custom language code used for the `lang` template variable (for example: `en`, `fr`, `ru`).\n\nThis setting only applies when `#arb-editor.appLocalizationsCodeLensLanguageMode#` is `custom`."
        },
        "arb-editor.appLocalizationsCodeLensTemplate": {
          "type": "string",
          "default": "[${lang}]: \"${value}\"",
          "markdownDescription": "Template used to render AppLocalizations CodeLens text.\n\nAvailable variables:\n- `${value}`: localized value from the resolved `.arb` file.\n- `${path}`: full path to the resolved `.arb` file.\n- `${filename}`: filename of the resolved `.arb` file.\n- `${lang}`: resolved language code (`en`, `fr`, `ru`)."
        }
      }
    }
  },
  "keywords": [
    "Flutter",
    "arb",
    "localization",
    "l10n",
    "i18n",
    "internationalization"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.1",
    "@types/vscode": "^1.106.1",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1",
    "glob": "^13.0.0",
    "globals": "^16.5.0",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "xregexp": "^5.1.2",
    "yaml": "^2.8.2"
  }
}
